<?php session_start();//GESTION DES GETSif(!empty($_GET['suppr_note']) AND isset($_GET['id_customer']) AND !empty($_GET['id_customer']) AND is_numeric($_GET['id_customer'])){    global $db;    $note = $db->SQLFix($_GET['suppr_note']);    $id_customer = $db->SQLFix($_GET['id_customer']);    $db->Query('DELETE FROM notes WHERE id = "'.$note.'" AND id_client = "'.$id_customer.'" AND compte_principal = "'.$_SESSION['compte_principal'].'"');    $log = new addLog('à supprimé une note associée au client');    $log->setClient($id_customer);    $log->insert();    $_SESSION['notify'] = 'DeleteNote';    header('Location: ./c'.$id_customer.'#tab_tab_notes');    die();}//suppression servicesif(!empty($_GET['suppr_service']) AND isset($_GET['id_customer']) AND !empty($_GET['id_customer']) AND is_numeric($_GET['id_customer'])){    global $db;    $service = $db->SQLFix($_GET['suppr_service']);    $id_customer = $db->SQLFix($_GET['id_customer']);    $db->Query('DELETE FROM mdp WHERE id = "'.$service.'" AND id_client = "'.$id_customer.'" AND compte_principal = "'.$_SESSION['compte_principal'].'"');    $log = new addLog('à supprimé un mot de passe associé au client');    $log->setClient($id_customer);    $log->insert();    $_SESSION['notify'] = 'DeleteServicePassword';    header('Location: ./c'.$id_customer);    die();}//démarrage du chrono maintenanceif($_GET['action'] == 'start' AND isset($_GET['id_customer']) AND !empty($_GET['id_customer']) AND is_numeric($_GET['id_customer']) AND right('pack_maintenance', 2)){    global $db;    $id_customer = $db->SQLfix($_GET['id_customer']);    $sql = 'SELECT COUNT(*) AS nb        FROM chrono_maintenance        WHERE debut > 0        AND id_client = "'.$id_customer.'"        AND compte_principal ="'.$_SESSION['compte_principal'].'"  ';    $db->Query($sql);    $d = $db->Row();    if(!$d->nb)    {        $sql = 'SELECT COUNT(*) AS nb        FROM chrono_maintenance        WHERE id_client = "'.$id_customer.'"        AND compte_principal ="'.$_SESSION['compte_principal'].'"  ';        $db->Query($sql);        $d = $db->Row();        if($d->nb)            $sql = 'UPDATE chrono_maintenance SET debut = "'.time().'"                    WHERE id_client = "'.$id_customer.'"                    AND compte_principal = "'.$_SESSION['compte_principal'].'"                    ';        else            $sql = 'INSERT INTO chrono_maintenance (id_client, debut, compte_principal)                    VALUES ("'.$id_customer.'", "'.time().'", "'.$_SESSION['compte_principal'].'")            ';        $db->Query($sql);        $log = New addLog('a démarré le chronomètre du pack maintenance du client');        $log->setClient($id_customer);        $log->insert();    }    header('Location: ./c'.$id_customer);}//arret du chrono maintenanceif($_GET['action'] == 'stop' AND isset($_GET['id_customer']) AND !empty($_GET['id_customer']) AND is_numeric($_GET['id_customer']) AND right('pack_maintenance', 2)){    global $db;    $id_customer = $db->SQLfix($_GET['id_customer']);    $sql = 'SELECT debut, buffer        FROM chrono_maintenance        WHERE id_client = "' . $id_customer . '"        AND compte_principal ="' . $_SESSION['compte_principal'] . '"  ';    $db->Query($sql);    $d = $db->Row();    if ($d->debut)    {        $difference = time() - $d->debut + $d->buffer;        $sql = 'UPDATE chrono_maintenance SET debut = 0, buffer = "'.$difference.'"                    WHERE id_client = "'.$id_customer.'"                    AND compte_principal = "'.$_SESSION['compte_principal'].'"                    ';        $db->Query($sql);        $log = New addLog('a arrêté le chronomètre du pack maintenance du client');        $log->setClient($id_customer);        $log->insert();    }    header('Location: ./c'.$id_customer);}if($_GET['action'] == 'add' AND isset($_GET['id_customer']) AND !empty($_GET['id_customer']) AND is_numeric($_GET['id_customer']) AND isset($_GET['id_contact']) AND !empty($_GET['id_contact']) AND is_numeric($_GET['id_contact'])){    global $db;    $id_customer = $db->SQLfix($_GET['id_customer']);    $id_contact = $db->SQLfix($_GET['id_contact']);    $db->Query('SELECT COUNT(*) AS nb_pro FROM clients WHERE id = "'.$id_customer.'" AND pro_part = 1 AND compte_principal="'.$_SESSION['compte_principal'].'" ');    $row = $db->Row();    $nb_pro = $row->nb_pro;    $db->Query('SELECT COUNT(*) AS nb_part FROM clients WHERE id = "'.$id_contact.'" AND pro_part = 2 AND id_parent = 0 AND compte_principal="'.$_SESSION['compte_principal'].'" ');    $row = $db->Row();    $nb_part = $row->nb_part;    if($nb_pro AND $nb_part)        $db->Query('UPDATE clients SET id_parent = "'.$id_customer.'" WHERE id="'.$id_contact.'"  AND compte_principal="'.$_SESSION['compte_principal'].'" ');    $log = New addLog('a ajouté un particulié à la société');    $log->setClient($id_customer);    $log->insert();    header('Location: c'.$id_customer);}if($_GET['action'] == 'supp' AND isset($_GET['id_customer']) AND !empty($_GET['id_customer']) AND is_numeric($_GET['id_customer']) AND isset($_GET['id_contact']) AND !empty($_GET['id_contact']) AND is_numeric($_GET['id_contact'])){    global $db;    $id_customer = $db->SQLfix($_GET['id_customer']);    $id_contact = $db->SQLfix($_GET['id_contact']);    $db->Query('UPDATE clients                 SET id_parent=0                 WHERE id="'.$id_contact.'"                 AND id_parent = "'.$id_customer.'"                AND compte_principal="'.$_SESSION['compte_principal'].'" ');    $log = New addLog('a supprimé un particulier de la société');    $log->setClient($id_customer);    $log->insert();    header('Location: c'.$id_customer);    }if($_GET['action'] == 'convertir' AND isset($_GET['id_customer']) AND !empty($_GET['id_customer']) AND is_numeric($_GET['id_customer']) ){       global $db;    $id_customer = $db->SQLfix($_GET['id_customer']);        $db->Query('SELECT pro_part FROM clients WHERE id="'.$id_customer.'" AND compte_principal="'.$_SESSION['compte_principal'].'" ');    $row = $db->Row();    if($row->pro_part == 1)    {        $pro_part = 2;        $titre = 'M';        $log = New addLog('a converti le client en particulier');        $log->setClient($id_customer);        $log->insert();        $_SESSION['notify'] = 'ConvertCustomerToPart';    }    else    {        $pro_part = 1;        $titre = "Sté";        $log = New addLog('a converti le client en professionnel');        $log->setClient($id_customer);        $log->insert();        $_SESSION['notify'] = 'ConvertCustomerToPro';    }    //$sql  = 'UPDATE clients SET pro_part="'.$pro_part.'" AND titre="'.$titre.'" WHERE id = "'.$id_customer.'" AND compte_principal="'.$_SESSION['compte_principal'].'" '    $db->Query('UPDATE clients SET pro_part="'.$pro_part.'", titre="'.$titre.'" WHERE id = "'.$id_customer.'" AND compte_principal="'.$_SESSION['compte_principal'].'" ');        header('Location: c'.$id_customer);    die();    }/* * Supprimer commentaire */if(isset($_GET['suppr_comment']) AND !(empty($_GET['suppr_comment']))){    $id_comment = $db->SQLFix($_GET['suppr_comment']);    $id_customer = $db->SQLfix($_GET['id_customer']);    $sql = 'DELETE FROM commentaires WHERE id_client = "'.$id_customer.'" AND id="'.$id_comment.'" AND compte_principal = "'.$_SESSION['compte_principal'].'"';    $db->Query($sql);    $log = New addLog('a supprimé un commentaire du client');    $log->setClient($id_customer);    $log->insert();    header('location: ./c'.$id_customer.'#tab_tab_comments');    die();}?>