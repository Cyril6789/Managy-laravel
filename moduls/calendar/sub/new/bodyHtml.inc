adresse']  = $row->adresse.' '.$row->cp.' '.$row->ville;                    $tab_rdv[$i]['lieu_client_atelier']  = $row->lieu_client_atelier;                    $i++;                }                                //Interventions sur site            $db->Query('SELECT i.id_inter, rdv_debut, rdv_fin, titre, nom, prenom, clients.adresse, clients.cp, clients.ville                         FROM interventions AS i                         INNER JOIN clients                         ON (clients.id = i.id_client)                         AND (clients.compte_principal="'.$_SESSION['compte_principal'].'")                         WHERE i.compte_principal="'.$_SESSION['compte_principal'].'"                         AND i.rdv_annule = "0" AND type_atelier_rdv = "2" ');            $tab_inter_site = Array();            $i=0;            while($row = $db->Row())            {                                $tab_inter_site[$i]['id'] = $row->id_inter;                $tab_inter_site[$i]['title'] = $row->titre.' '.$row->nom.' '.$row->prenom;                $tab_inter_site[$i]['jour'] = date('d', $row->rdv_debut);                $tab_inter_site[$i]['mois'] = date('m', $row->rdv_debut) - 1;                $tab_inter_site[$i]['annee'] = date('Y', $row->rdv_debut);                $tab_inter_site[$i]['heure']  = date('H', $row->rdv_debut);                $tab_inter_site[$i]['minute']  = date('i', $row->rdv_debut);                $tab_inter_site[$i]['jourf'] = date('d', $row->rdv_fin);                $tab_inter_site[$i]['moisf'] = date('m', $row->rdv_fin) - 1;                $tab_inter_site[$i]['anneef'] = date('Y', $row->rdv_fin);                $tab_inter_site[$i]['heuref']  = date('H', $row->rdv_fin);                $tab_inter_site[$i]['minutef']  = date('i', $row->rdv_fin );                $tab_inter_site[$i]['adresse']  = $row->adresse.' '.$row->cp.' '.$row->ville;                $i++;            }                ob_start();                include('./templates/'.TEMPLATE_NAME.'/sub/new_rdv.php');                $ModulContent = ob_get_contents();                ob_end_clean();            }        }    }    else    {        if(is_file('./templates/'.TEMPLATE_NAME.'/pages/no_rights.php'))        {                ob_start();                include('./templates/'.TEMPLATE_NAME.'/pages/no_right.php');                $ModulContent = ob_get_contents();                ob_end_clean();        }    }?>