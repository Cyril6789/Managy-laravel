<?php session_start();//GESTION DES GETS//Supprimer inter sur siteif(isset($_GET['action']) AND !empty($_GET['action']) AND $_GET['action'] == 'suppr_rdv' AND !empty($_GET['id_inter']) AND is_numeric($_GET['id_inter'])){    if(right('inter', 3))    {        global $db;        $id_inter = (int) $db->SQLfix($_GET['id_inter']);            $db->Query('SELECT COUNT(*) AS nb FROM prise_en_charge WHERE id_intervention = "'.$id_inter.'" AND id_staff = "'.$_SESSION['id'].'"  AND compte_principal="'.$_SESSION['compte_principal'].'" ');        $row = $db->Row();        $pris_en_charge = $row->nb;            if($pris_en_charge)        {            $db->Query('SELECT time_cloture FROM interventions WHERE id_inter="'.$id_inter.'"  AND compte_principal="'.$_SESSION['compte_principal'].'" ');            $row = $db->Row();            if($row->time_cloture)                $cloture = 1;            else                $cloture = 0;            if(!$cloture)            {                $sql = 'UPDATE interventions SET rdv_annule = "1" , time_cloture = "'.time().'" WHERE id_inter="'.$id_inter.'"  AND compte_principal="'.$_SESSION['compte_principal'].'"  ';                                  $db->Query($sql);                       $log = New addLog('a supprimé l\'intervention sur site');                $log->setInter($id_inter);                $log->insert();                $_SESSION['notify'] = 'DeleteInterSite';                                changements_interventions($id_inter);                header('Location: intervention-'.$id_inter);                die();            }        }    }    }//PRENDRE EN CHARGEif(isset($_GET['action']) AND !empty($_GET['action']) AND $_GET['action'] == 'pec' AND !empty($_GET['id_inter']) AND is_numeric($_GET['id_inter'])){    if(right('inter', 3))    {            global $db;        $id_inter = $db->SQLfix($_GET['id_inter']);        $db->Query('SELECT COUNT(*) AS nb FROM prise_en_charge WHERE id_intervention = "'.$id_inter.'" AND id_staff = "'.$_SESSION['id'].'"  AND compte_principal="'.$_SESSION['compte_principal'].'" ');                $row = $db->Row();        $pris_en_charge = $row->nb;        if(!$pris_en_charge)        {            $db->Query('INSERT INTO prise_en_charge                     (id_staff, id_intervention, time, compte_principal)                     VALUES                     ("'.$_SESSION['id'].'", "'.$id_inter.'", "'.time().'", "'.$_SESSION['compte_principal'].'"  )');            $log = New addLog('a pris en charge l\'intervention');            $log->setInter($id_inter);            $log->insert();            $_SESSION['notify'] = 'PecInter';            $auto = new automatismes($id_inter, 'pec');            header('Location: ./i'.$id_inter);            die();        }    }}//NE PLUS PRENDRE EN CHARGEif(isset($_GET['action']) AND !empty($_GET['action']) AND $_GET['action'] == 'nppec' AND !empty($_GET['id_inter']) AND is_numeric($_GET['id_inter'])){    if(right('inter', 3))    {            global $db;        $id_inter = $db->SQLfix($_GET['id_inter']);                $db->Query('DELETE FROM prise_en_charge WHERE id_staff ="'.$_SESSION['id'].'" AND id_intervention = "'.$id_inter.'"  AND compte_principal="'.$_SESSION['compte_principal'].'" ');        $log = New addLog('ne prend plus en charge l\'intervention');                $log->setInter($id_inter);                $log->insert();        $_SESSION['notify'] = 'NpecInter';        header('Location: ./i'.$id_inter);        die();    }}//DECLOTURERif(isset($_GET['action']) AND !empty($_GET['action']) AND $_GET['action'] == 'decloture' AND !empty($_GET['id_inter']) AND is_numeric($_GET['id_inter'])){    if(right('inter', 8))    {            global $db;        $id_inter = $db->SQLfix($_GET['id_inter']);                $db->Query('UPDATE interventions SET time_cloture = 0, rdv_annule = "0" WHERE id_inter = "'.$id_inter.'"  AND compte_principal="'.$_SESSION['compte_principal'].'" ');        $db->Query('DELETE FROM maintenance WHERE id_inter = "'.$id_inter.'" ');        $log = New addLog('a déclôturé l\'intervention');                $log->setInter($id_inter);                $log->insert();        $sql = 'SELECT clients.id as id_c                    FROM interventions                    INNER JOIN clients                    ON (interventions.id_client = clients.id)                    AND (clients.compte_principal = "'.$_SESSION['compte_principal'].'")                    WHERE interventions.id_inter = "'.$id_inter.'"                    AND interventions.compte_principal = "'.$_SESSION['compte_principal'].'"                    ';        $db->Query($sql);        $row = $db->Row();        $id_client = $row->id_c;        $notification = new notificationMail('3');        $notification->tab_parse(Array('%id_inter%' => $id_inter, '%client%' => $id_client, '%prenom_staff%' => $_SESSION['prenom']));        $notification->sendMail();        changements_interventions($id_inter);        $_SESSION['notify'] = 'DeclotureInter';        header('Location: ./i'.$id_inter);        die();    }}//Suppression commandeif(!empty($_GET['suppr_cde']) AND is_numeric($_GET['suppr_cde']) AND right('commandes', 3)){    global $db;    $id_cde = $db->SQLfix($_GET['suppr_cde']);    $id_inter = $db->SQLfix($_GET['id_inter']);        $db->Query('DELETE FROM commandes WHERE id="'.$id_cde.'" AND id_inter="'.$id_inter.'" AND compte_principal="'.$_SESSION['compte_principal'].'" ');    changements_interventions($id_inter);    $log = New addLog('a supprimé une commande');    $log->setInter($id_inter);    $log->insert();    $_SESSION['notify'] = 'DeleteOrder';    header('Location: ./i'.$id_inter);    die();}//Reception commandeif(!empty($_GET['reception_cde']) AND is_numeric($_GET['reception_cde']) AND right('commandes', 5)){    global $db;    $id_cde = $db->SQLfix($_GET['reception_cde']);    $id_inter = $db->SQLfix($_GET['id_inter']);        $db->Query('UPDATE commandes SET cde_recue="1", date_reception="'.time().'" WHERE id="'.$id_cde.'" AND id_inter="'.$id_inter.'" AND compte_principal="'.$_SESSION['compte_principal'].'" ');    changements_interventions($id_inter);    $log = New addLog('a marqué la commande comme receptionnée');    $log->setInter($id_inter);    $log->insert();    $auto = new automatismes($id_inter, 'rcommande');    $_SESSION['notify'] = 'ReceiveOrder';    header('Location: ./i'.$id_inter);    die();}//Deréception commandeif(!empty($_GET['dereception_cde']) AND is_numeric($_GET['dereception_cde']) AND right('commandes', 5)){    global $db;    $id_cde = $db->SQLfix($_GET['dereception_cde']);    $id_inter = $db->SQLfix($_GET['id_inter']);        $db->Query('UPDATE commandes SET cde_recue="0" WHERE id="'.$id_cde.'" AND id_inter="'.$id_inter.'" AND compte_principal="'.$_SESSION['compte_principal'].'" ');    changements_interventions($id_inter);    $log = New addLog('a marqué la commande comme non receptionnée');    $log->setInter($id_inter);    $log->insert();    $_SESSION['notify'] = 'NoReceiveOrder';    header('Location: ./i'.$id_inter);    die();}//Suppression sstif(!empty($_GET['suppr_sst']) AND is_numeric($_GET['suppr_sst']) AND right('soustraitances', 3)){    global $db;    $id_sst = $db->SQLfix($_GET['suppr_sst']);    $id_inter = $db->SQLfix($_GET['id_inter']);        $db->Query('DELETE FROM sous_traitances WHERE id="'.$id_sst.'" AND id_inter="'.$id_inter.'" AND compte_principal="'.$_SESSION['compte_principal'].'" ');    changements_interventions($id_inter);    $log = New addLog('a supprimé la mise en sous traitance de l\'intervention');    $log->setInter($id_inter);    $log->insert();    $_SESSION['notify'] = 'DeleteSousTraitance';    header('Location: ./i'.$id_inter);    die();}//Retour sstif(!empty($_GET['retour_sst']) AND is_numeric($_GET['retour_sst']) AND right('soustraitances', 5)){    global $db;    $id_sst = $db->SQLfix($_GET['retour_sst']);    $id_inter = $db->SQLfix($_GET['id_inter']);        $db->Query('UPDATE sous_traitances SET retour="1", date_retour="'.time().'" WHERE id="'.$id_sst.'" AND id_inter="'.$id_inter.'" AND compte_principal="'.$_SESSION['compte_principal'].'" ');    changements_interventions($id_inter);    $log = New addLog('a receptionné le retour de sous-traitance');    $log->setInter($id_inter);    $log->insert();    $_SESSION['notify'] = 'RetourSousTraitance';    $auto = new automatismes($id_inter, 'rstt');    header('Location: ./i'.$id_inter);    die();}//Deréception sous-traitanceif(!empty($_GET['deretour_sst']) AND is_numeric($_GET['deretour_sst']) AND right('soustraitances', 5)){    global $db;    $id_sst = $db->SQLfix($_GET['deretour_sst']);    $id_inter = $db->SQLfix($_GET['id_inter']);        $db->Query('UPDATE sous_traitances SET retour="0" WHERE id="'.$id_sst.'" AND id_inter="'.$id_inter.'" AND compte_principal="'.$_SESSION['compte_principal'].'" ');    changements_interventions($id_inter);    $log = New addLog('a annulé le retour de sous-traitance');    $log->setInter($id_inter);    $log->insert();    $_SESSION['notify'] = 'NoRetourSousTraitance';    header('Location: ./i'.$id_inter);    die();}/* * Supprimer commentaire */if(isset($_GET['suppr_comment']) AND !(empty($_GET['suppr_comment']))){    $id_comment = $db->SQLFix($_GET['suppr_comment']);    $id_inter = $db->SQLfix($_GET['id_inter']);    $sql = 'DELETE FROM commentaires WHERE id_inter = "'.$id_inter.'" AND id="'.$id_comment.'" AND compte_principal = "'.$_SESSION['compte_principal'].'"';    $db->Query($sql);    header('location: ./i'.$id_inter.'#tab_inter_comments');    die();}?>