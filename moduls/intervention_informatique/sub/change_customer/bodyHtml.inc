<?php session_start();    if(right('inter', 2) AND (END_SUBSCRIPTION > time() - (15 * 24 * 60 * 60)))    {        if(!empty($_GET['id_inter'])) {            if (empty($_GET['id_customer'])) //Aucun client selectionné, on demande l'appelle d'un client            {                if (is_file('./moduls/customers/classes/SelectCustomer.class.inc')) {                    require_once('./moduls/customers/classes/SelectCustomer.class.inc');                    $selecteur_page = new SelectCustomer('intervention-change-customer-' . $_GET['id_inter'] . '-', 'intervention-change-customer-' . $_GET['id_inter']);                    //$selecteur->no_parent();                    $ModulContent = $selecteur_page->getHTML();                }            }            else //le client est choisi            {                $id_inter = $db->SQLFix($_GET['id_inter']);                $id_customer = $db->SQLFix($_GET['id_customer']);                $sql = 'UPDATE interventions SET id_client = "' . $id_customer . '", id_contact="0" WHERE id_inter="' . $id_inter . '" AND compte_principal="' . $_SESSION['compte_principal'] . '" ';                $db->Query($sql);                $log = New addLog('a modifié le client associé à l\'intervention.');                $log->setInter($id_inter);                $log->insert();                header('location: ./i' . $id_inter);            }        }        else {            header('location: ./dashboard');        }    }    else {        if (is_dir('./templates/' . TEMPLATE_NAME . '/pages/')) {            ob_start();            include('./templates/' . TEMPLATE_NAME . '/pages/no_right.php');            $ModulContent = ob_get_contents();            ob_end_clean();        }    }?>