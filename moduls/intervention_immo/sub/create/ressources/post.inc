<?php session_start();if(isset($_POST['send']) AND !empty($_POST['send'])){    global $db;    print_r($_POST);    $type = $db->SQLfix($_POST['type']);     $adresse = $db->SQLfix($_POST['adresse']);     $cp = $db->SQLfix($_POST['cp']);     $ville = $db->SQLfix($_POST['ville']);     $id_client = $db->SQLfix($_POST['id_client']);    $prix = $db->SQLfix($_POST['prix']);    $ges = $db->SQLfix($_POST['ges']);    $dpe = $db->SQLfix($_POST['dpe']);    $description = $db->SQLfix($_POST['description']);    $id_type_affaire = $db->SQLfix($_POST['id_type_affaire']);    if($_POST['urgente'] == 'on')        $urgente = 1;    else        $urgente = 0;    $db->Query('SELECT id_inter FROM interventions WHERE compte_principal="'.$_SESSION['compte_principal'].'" ORDER BY id_inter DESC LIMIT 1');    $row = $db->Row();    $derniere_inter = $row->id_inter;    $nouvelle_inter = $derniere_inter + 1;    $db->Query('INSERT INTO interventions (id_inter, id_staff_ouverture, time_ouverture, id_client, type_location_vente, id_type_affaire, adresse, cp, ville, urgente, prix, dpe, ges, description, compte_principal) VALUES ("'.$nouvelle_inter.'", "'.$_SESSION['id'].'", "'.time().'", "'.$id_client.'","'.$type.'", "'.$id_type_affaire.'", "'.$adresse.'", "'.$cp.'", "'.$ville.'", "'.$urgente.'", "'.$prix.'", "'.$ges.'", "'.$dpe.'", "'.$description.'",  "'.$_SESSION['compte_principal'].'" )');    $log = New addLog('a créé l\'intervention');    $log->setInter($nouvelle_inter);    $log->insert();   header('Location: affaire-'.$nouvelle_inter);}?>